<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="LlamaCppLauncher.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LlamaCppLauncher">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Editorial industrial — warm charcoal + sage. No blue, purple, neon. -->
            <Color x:Key="Ink">#FF0F100F</Color>
            <Color x:Key="Charcoal">#FF171816</Color>
            <Color x:Key="Stone">#FF21231F</Color>
            <Color x:Key="StoneRaised">#FF2A2C27</Color>
            <Color x:Key="Edge">#FF363933</Color>
            <Color x:Key="Parchment">#FFE4E6DF</Color>
            <Color x:Key="Ash">#FF95998F</Color>
            <Color x:Key="AshDim">#FF666A60</Color>
            <Color x:Key="Sage">#FF8FA37A</Color>
            <Color x:Key="SageDim">#FF6B7D5A</Color>
            <Color x:Key="SageHover">#FFA3B68E</Color>
            <Color x:Key="Moss">#FF7A8F6E</Color>
            <Color x:Key="Clay">#FFB07A5C</Color>
            <Color x:Key="Sand">#FFC4A574</Color>

            <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Ink}" />
            <SolidColorBrush x:Key="CharcoalBrush" Color="{StaticResource Charcoal}" />
            <SolidColorBrush x:Key="StoneBrush" Color="{StaticResource Stone}" />
            <SolidColorBrush x:Key="StoneRaisedBrush" Color="{StaticResource StoneRaised}" />
            <SolidColorBrush x:Key="EdgeBrush" Color="{StaticResource Edge}" />
            <SolidColorBrush x:Key="ParchmentBrush" Color="{StaticResource Parchment}" />
            <SolidColorBrush x:Key="AshBrush" Color="{StaticResource Ash}" />
            <SolidColorBrush x:Key="AshDimBrush" Color="{StaticResource AshDim}" />
            <SolidColorBrush x:Key="SageBrush" Color="{StaticResource Sage}" />
            <SolidColorBrush x:Key="SageDimBrush" Color="{StaticResource SageDim}" />

            <Color x:Key="SystemAccentColor">#FF8FA37A</Color>
            <Color x:Key="SystemAccentColorLight1">#FFA3B68E</Color>
            <Color x:Key="SystemAccentColorLight2">#FFB8C9A4</Color>
            <Color x:Key="SystemAccentColorDark1">#FF6B7D5A</Color>
            <Color x:Key="SystemAccentColorDark2">#FF4F5C43</Color>
            <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="{StaticResource Sage}" />
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource Sage}" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource SageHover}" />
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource Parchment}" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource Ash}" />
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource StoneRaised}" />
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource Stone}" />
            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource Edge}" />
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="{StaticResource Stone}" />
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="{StaticResource Charcoal}" />
            <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource Ink}" />

            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AshBrush}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="40" />
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource StoneBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="18,16" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource SageBrush}" />
                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource ParchmentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14,9" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="QuietButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource StoneRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ParchmentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource StoneRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ParchmentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="10,8" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource StoneRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ParchmentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style TargetType="NumberBox">
                <Setter Property="Background" Value="{StaticResource StoneRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ParchmentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style TargetType="ToggleSwitch">
                <Setter Property="Foreground" Value="{StaticResource ParchmentBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
